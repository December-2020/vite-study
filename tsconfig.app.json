/* 定义项目中除vite.config.ts以外文件的ts编译规则 */
{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "preserve",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* 必须设置相对路径才能使用别名 */
    "baseUrl": "./",
    /* 设置别名 */
    "paths": {
      "@/*": ["src/*"],
      "#/*": ["types/*"],
      "#Api/*": ["apiTypes/*"]
    },
    /**
     * 指定全局组件类型(element官方建议)
     */
    "types": ["element-plus/global"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    /* 引入ts 类型文件 */
    "types/**/*.d.ts"
  ]
}
